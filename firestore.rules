rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Fields: name, email, phone, address, taxId
    //
    // Collection: technicians
    // Fields: name, email, phone, specialty
    //
    // Collection: suppliers
    // Fields: name, email, phone, address, taxId
    //
    // Collection: serviceOrders
    // Fields: customerId, technicianIds, supplierId, status, description, hoursWorked, laborCost, kmDriven, kmValue, parts, servicePhotos, location, paymentMethod, totalValue, createdAt, updatedAt
    //
    // Collection: settings
    // Fields: kmValue, laborHourValue
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "igonaugustobarbosa@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function getTenantId() {
      let data = getUserData();
      return data != null ? data.tenantId : null;
    }

    function isOwner(data) {
      return isAuthenticated() && data != null && (data.tenantId == getTenantId() || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.tenantId == getTenantId());
      allow update: if isAuthenticated() && (isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role && request.resource.data.tenantId == resource.data.tenantId));
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId();
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow delete: if isAdmin();
    }

    match /technicians/{technicianId} {
      allow read: if isAuthenticated() && (isAdmin() || resource == null || resource.data.tenantId == getTenantId());
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId();
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId();
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow delete: if isAdmin();
    }

    match /serviceOrders/{orderId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId();
      allow update: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.tenantId == getTenantId()));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated() && (settingId == getTenantId() || isAdmin());
      allow write: if isAuthenticated() && (settingId == getTenantId() || isAdmin());
    }

    match /activities/{activityId} {
      allow list: if isAuthenticated() && (resource.data.tenantId == getTenantId() || isAdmin());
      allow get: if isAuthenticated() && (resource.data.tenantId == getTenantId() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId();
      allow update, delete: if isAdmin();
    }
  }
}
